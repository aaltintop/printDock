.cache
build
node_modules

# Source control & editor
.git
.gitignore
.gitattributes
.cursor
.vscode
.idea
.DS_Store
**/.DS_Store

# Docs / repo metadata (not needed in the runtime image)
docs
*.md
README*
LICENSE*

# Tests / fixtures
tests
**/*.test.*
**/__tests__/**
coverage
vitest.config.*

# Generated / extension build artefacts (re-generated by `shopify app deploy`,
# not by Cloud Run, so they have no business in the Cloud Run image).
extensions/*/dist
extensions/*/.shopify
extensions/*/generated
extensions/*/node_modules
extensions/*/build
extensions/*/target

# Local dev helpers
terminals
.shopify
.npm
*.log
*.tsbuildinfo

# Local env files (Cloud Run gets env vars via --env-vars-file at deploy time;
# never bake .env files into the image).
.env
.env.*
.cloudrun.env
shopify.web.toml.local

# Misc
tmp
.tmp
*.zip
*.tar
*.tgz
