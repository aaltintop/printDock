export PROJECT_ID="printdock-976d5"
export SERVICE_NAME="printdock-service"
# Must match the Cloud Run region (URL …-uc.a.run.app → us-central1). Change if you redeploy elsewhere.
export SERVICE_REGION="us-central1"
export FIREBASE_PROJECT_ID="printdock-976d5"
export FIREBASE_STORAGE_BUCKET="printdock-976d5.firebasestorage.app"
# Must match shopify.app.toml [access_scopes] scopes
export SCOPES="read_products,read_orders,read_themes"
# Managed pricing by default on Cloud Run (deploy script sets the same).
export SHOPIFY_BILLING_MODE="managed"
